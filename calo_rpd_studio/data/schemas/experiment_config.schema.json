{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CALO-RPD Studio Experiment Configuration",
  "type": "object",
  "required": [
    "case_name",
    "algorithms",
    "runs",
    "master_seed",
    "population_size",
    "budget",
    "objective",
    "variables",
    "scenarios"
  ],
  "properties": {
    "case_name": {
      "type": "string"
    },
    "algorithms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "runs": {
      "type": "integer",
      "minimum": 1
    },
    "master_seed": {
      "type": "integer",
      "minimum": 0
    },
    "population_size": {
      "type": "integer",
      "minimum": 2
    },
    "parallel_workers": {
      "type": "integer",
      "minimum": 1
    },
    "execution_backend": {
      "type": "string",
      "enum": [
        "weighted_split",
        "adaptive_hybrid",
        "gpu_preferred",
        "cpu_only"
      ]
    },
    "gpu_utilization_target": {
      "type": "integer",
      "minimum": 10,
      "maximum": 100
    },
    "cpu_utilization_target": {
      "type": "integer",
      "minimum": 10,
      "maximum": 100
    },
    "gpu_memory_limit": {
      "type": "integer",
      "minimum": 20,
      "maximum": 100
    },
    "gpu_parallel_jobs": {
      "type": "integer",
      "minimum": 1,
      "maximum": 16
    },
    "xpu_utilization_target": {
      "type": "integer",
      "minimum": 10,
      "maximum": 100
    },
    "xpu_memory_limit": {
      "type": "integer",
      "minimum": 20,
      "maximum": 100
    },
    "xpu_parallel_jobs": {
      "type": "integer",
      "minimum": 1,
      "maximum": 16
    },
    "system_memory_limit": {
      "type": "integer",
      "minimum": 20,
      "maximum": 100
    },
    "cuda_task_share": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "default": 50
    },
    "xpu_task_share": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "default": 30
    },
    "cpu_task_share": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "default": 20
    },
    "strict_device_shares": {
      "type": "boolean",
      "default": true
    }
  },
  "additionalProperties": true
}
