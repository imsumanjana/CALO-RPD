{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CALO-RPD Studio Experiment Configuration",
  "type": "object",
  "required": [
    "case_name",
    "algorithms",
    "runs",
    "master_seed",
    "population_size",
    "budget",
    "objective",
    "variables",
    "scenarios"
  ],
  "properties": {
    "case_name": {
      "type": "string"
    },
    "algorithms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "runs": {
      "type": "integer",
      "minimum": 1
    },
    "master_seed": {
      "type": "integer",
      "minimum": 0
    },
    "population_size": {
      "type": "integer",
      "minimum": 2
    },
    "parallel_workers": {
      "type": "integer",
      "minimum": 1
    },
    "execution_backend": {
      "type": "string",
      "enum": [
        "cuda_priority",
        "cuda_only",
        "throughput_auto",
        "weighted_split",
        "adaptive_hybrid",
        "gpu_preferred",
        "cpu_only"
      ]
    },
    "gpu_utilization_target": {
      "type": "integer",
      "minimum": 10,
      "maximum": 100
    },
    "cpu_utilization_target": {
      "type": "integer",
      "minimum": 10,
      "maximum": 100
    },
    "gpu_memory_limit": {
      "type": "integer",
      "minimum": 20,
      "maximum": 100
    },
    "gpu_parallel_jobs": {
      "type": "integer",
      "minimum": 1,
      "maximum": 16
    },
    "xpu_utilization_target": {
      "type": "integer",
      "minimum": 10,
      "maximum": 100
    },
    "xpu_memory_limit": {
      "type": "integer",
      "minimum": 20,
      "maximum": 100
    },
    "xpu_parallel_jobs": {
      "type": "integer",
      "minimum": 1,
      "maximum": 16
    },
    "system_memory_limit": {
      "type": "integer",
      "minimum": 20,
      "maximum": 100
    },
    "cuda_task_share": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "default": 80
    },
    "xpu_task_share": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "default": 10
    },
    "cpu_task_share": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "default": 10
    },
    "strict_device_shares": {
      "type": "boolean",
      "default": true
    },
    "throughput_engine_enabled": {
      "type": "boolean",
      "default": true
    },
    "persistent_accelerator_workers": {
      "type": "boolean",
      "default": true
    },
    "cross_run_batching": {
      "type": "boolean",
      "default": true
    },
    "cross_run_batch_window_ms": {
      "type": "number",
      "exclusiveMinimum": 0,
      "default": 4.0
    },
    "max_cross_run_batch": {
      "type": "integer",
      "minimum": 1,
      "default": 4096
    },
    "automatic_batch_calibration": {
      "type": "boolean",
      "default": true
    },
    "calibration_batch_sizes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "integer",
        "minimum": 1
      },
      "default": [
        16,
        32,
        64,
        128,
        256
      ]
    },
    "calibration_repetitions": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "throughput_profile_path": {
      "type": "string",
      "default": "results_data/throughput_profile_v31.json"
    },
    "telemetry_iteration_interval": {
      "type": "integer",
      "minimum": 1,
      "default": 10
    },
    "buffered_trace_writes": {
      "type": "boolean",
      "default": true
    },
    "device_resident_execution": {
      "type": "boolean",
      "default": true
    },
    "cuda_priority_work_stealing": {
      "type": "boolean",
      "default": true
    }
  },
  "additionalProperties": true
}
